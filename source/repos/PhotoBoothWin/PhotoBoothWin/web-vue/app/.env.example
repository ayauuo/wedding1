# ========== 開發／除錯 ==========
# 開發時起始頁面（0=待機 1=選版型 2=拍照 3=結果 4=列印中）
# 設為空或註解則不自動跳轉，維持待機
VITE_DEV_START_PAGE=0

# 直接進入濾鏡區測試（1 或 true）：啟動後直接到拍照頁的濾鏡區，不需相機，可指定測試圖
# 搭配 VITE_TEST_FILTER_IMAGE 使用；未設圖片時使用內建 SVG 占位圖
# VITE_TEST_FILTER_DIRECT=0
# VITE_TEST_FILTER_IMAGE=https://example.com/your-test-photo.jpg

# 預設版型索引（跳過選版型直接進拍照／預覽時使用，0=bk01 1=bk02 2=bk03 3=bk04）
VITE_DEFAULT_TEMPLATE_INDEX=0

# 拍照預覽畫面是否使用預設測試圖（1 或 true 時用 test0.jpg～test3.jpg）
VITE_PREVIEW_USE_TEST_IMAGES=0

# 網站靜音（1 或 true 時不播放倒數音效，僅顯示倒數數字）
VITE_MUTE=0

# 待機畫面輪播（1 或 true 時啟用輪播，目前使用同一張圖）
VITE_IDLE_CAROUSEL=0

# 結果畫面：尚未有合成圖時左側是否顯示版型占位（1 或 true 時用 bk01～bk04.png，右側維持 QR／列印 UI）
VITE_RESULT_SHOW_TEMPLATE_PLACEHOLDER=1

# 結果頁幾秒沒按列印就自動列印（預設 60）
VITE_RESULT_AUTO_PRINT_SEC=60

# 列印中畫面顯示幾秒後回待機並還原（DNP 通常不通知 C#，用此秒數模擬印完；預設 20）
VITE_PRINTING_SHOW_SEC=20

# 測試時不實際列印：1 或 true 時只顯示列印中畫面、不送 DNP、不寫入列印紀錄 CSV
VITE_SKIP_PRINT=0

# 每筆列印紀錄的收款金額（固定值，寫入 CSV 用，例如 100）
VITE_RECEIPT_AMOUNT=100

# 測試時不列印（VITE_SKIP_PRINT=1）時仍寫入列印紀錄 CSV：1 或 true 時測試也會寫 report，方便確認
VITE_LOG_PRINT_RECORD_WHEN_SKIP=1

# 正式環境請設 0 或 false：不允許雙擊空白鍵開啟開發者測試面板，避免被人跳過流程
VITE_ALLOW_DEV_PANEL=1

# ========== 伺服器／上傳 ==========
# 上傳目標網址（純網頁模式時，前端直接 POST 到此外部 API；WebView 模式由 C# 的 upload_url.txt 或 BoothBridge.UploadUrl 決定）
# VITE_UPLOAD_URL=https://your-server.com/api/upload.php

# 掃描 QR 後顯示相片／影片下載頁的基底網址（不含查詢參數，請與實際部署的 download-page 一致）
# 未設時 QR 會用 imageUrl 或 https://example.com/download 作為 fallback
# VITE_DOWNLOAD_PAGE_BASE_URL=https://your-server.com/download

# 離線模式（1 或 true 時不上傳、不產生 QR code；需在 buildFinalOutput 內實作此邏輯，目前尚未啟用）
# VITE_OFFLINE_MODE=0

# 結果頁是否顯示／產生 QR code（1 或 true 時啟用；未設或 0 為無 QR，進入 NoQR 結果頁）
VITE_QRCODE_ENABLED=0

# ========== 拍照行為 ==========
# 測試模式快速倒數：1 或 true 時拍照改為 2 秒倒數
# VITE_TEST_FAST_COUNTDOWN=0

# 立刻拍：1 或 true 時跳過倒數，強制立即拍攝（啟動後直接拍）
# VITE_SHOOT_IMMEDIATE=0

# 倒數秒數（畫面上顯示 10～1，此值即 10；改成 5 則顯示 5～1）
# VITE_COUNTDOWN_SECONDS=10

# 倒數減 5 秒模式（1 或 true）：實際倒數 = 上列秒數 - 5（至少 1）、對焦只觸發一次、C# 播放 web/assets/templates/music/倒數5秒拍照.mp3（須與 倒數10秒拍照.mp3 同目錄）
# VITE_COUNTDOWN_MINUS5_MODE=10

# 在哪些秒數時觸發單眼對焦（逗號分隔；僅對焦不拍攝，例 10,5 表示在 10 秒與 5 秒時對焦，拍攝只在 T=0）
# VITE_FOCUS_AT_SECONDS=10,5

# 對焦後 C# 等待鏡頭完成的毫秒數（傳給 trigger_evf_af_with_pause）
# VITE_FOCUS_WAIT_AFTER_MS=350

# 第一次對焦完成就拍照：1 或 true 時只對焦一次、立即拍照
# VITE_SHOOT_AFTER_FIRST_FOCUS=1

# 強制拍攝不等待對焦：1 或 true 時到時機就拍，不管有無對焦成功（避免 0x8D01）
# VITE_FORCE_CAPTURE_WITHOUT_AF=1

# ========== 使用記錄 ==========
# 專案名稱（用於 daily report 使用記錄 CSV、列印紀錄、Google 試算表）
# VITE_PROJECT_NAME=拍貼機

# 機器名稱（用於列印紀錄 CSV、Google 試算表；未設則 C# 用本機電腦名稱）
# VITE_MACHINE_NAME=頭文字D拍貼機_拍四格

# 非測試模式下是否寫入使用記錄到 daily report 資料夾（1 或 true 時寫入）
# VITE_LOG_USAGE=0

# 貼圖功能開關：1 或 true 時啟用貼圖（可拖曳、縮放、貼在照片上）；0 或 false 時隱藏貼圖選項
# VITE_STICKER_ENABLED=1

# ========== 紙鈔機／投幣器 ==========
# 紙鈔機開關：1 或 true 時啟用紙鈔機；0 或 false 時不啟動紙鈔機（兩者皆關閉時，點擊螢幕即可進入選版型）
# VITE_BILL_ACCEPTOR_ENABLED=1
# 投幣器開關：1 或 true 時啟用投幣器；0 或 false 時不啟動投幣器
# VITE_COIN_ACCEPTOR_ENABLED=1

# ========== 合成座標（進階） ==========
# 每格「寬,高,x,y」逗號串接，張數與版型一致。未設則用程式內建預設。
# 可依 QRcodePage 外框實際挖空位置調整，讓照片對齊框框。
# VITE_BK01_SYNTHESIS=544,471,43,244,544,471,42,1225,544,471,625,244,544,471,623,1061
# VITE_BK02_SYNTHESIS=547,405,39,667,547,405,39,1158,547,405,662,667,547,405,662,1158
# VITE_BK03_SYNTHESIS=524,502,56,1004,524,502,637,590
# VITE_BK04_SYNTHESIS=529,400,54,761,529,400,632,761,529,400,54,1290,529,400,632,1290
