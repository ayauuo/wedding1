<Page x:Class="PhotoBoothWin.Pages.RetakePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="HintText" Foreground="White" FontSize="38" HorizontalAlignment="Center"/>
            <TextBlock x:Name="CountdownText" Foreground="White" FontSize="120" HorizontalAlignment="Center" Margin="0,20,0,20"/>
            <TextBlock Text="重拍每張最多一次" Foreground="Gray" FontSize="22" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
