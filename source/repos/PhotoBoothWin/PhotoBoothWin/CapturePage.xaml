<Page x:Class="PhotoBoothWin.Pages.CapturePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Foreground="White" FontSize="34"/>
        <TextBlock x:Name="CountdownText" Grid.Row="1"
                   Foreground="White" FontSize="120"
                   HorizontalAlignment="Center" Margin="0,10,0,10"/>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,20,0,0">
            <Border BorderBrush="White" BorderThickness="2" Margin="8">
                <Image x:Name="Img1"/>
            </Border>
            <Border BorderBrush="White" BorderThickness="2" Margin="8">
                <Image x:Name="Img2"/>
            </Border>
            <Border BorderBrush="White" BorderThickness="2" Margin="8">
                <Image x:Name="Img3"/>
            </Border>
            <Border BorderBrush="White" BorderThickness="2" Margin="8">
                <Image x:Name="Img4"/>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
