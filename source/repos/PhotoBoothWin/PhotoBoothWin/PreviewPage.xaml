<Page x:Class="PhotoBoothWin.Pages.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">

    <Page.Resources>
        <!-- 濾鏡按鈕：被選中就紅框 -->
        <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="10"
                                BorderThickness="3"
                                BorderBrush="#444"
                                Background="#222"
                                Padding="14,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Red"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#888"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 照片外框：預設白框 -->
        <Style x:Key="PhotoBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <TextBlock Grid.ColumnSpan="2"
                   Text="四格預覽（點照片選擇 → 右側選濾鏡；每張最多重拍一次）"
                   Foreground="White" FontSize="30"/>

        <!-- 左：四張照片 + 重拍 -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,20,20,20">
            <StackPanel>
                <Border x:Name="PhotoBd1" Style="{StaticResource PhotoBorderStyle}"
                        MouseLeftButtonDown="Pick1">
                    <Image x:Name="Img1" Stretch="UniformToFill" Height="320"/>
                </Border>
                <Button x:Name="BtnRetake1" Content="重拍(最多一次)" Height="60" FontSize="18"
                        Margin="8,0,8,0" Click="Retake1"/>
                <TextBlock x:Name="TxtFilter1" Foreground="#BBB" FontSize="16" Margin="8,8,8,0"/>
            </StackPanel>

            <StackPanel>
                <Border x:Name="PhotoBd2" Style="{StaticResource PhotoBorderStyle}"
                        MouseLeftButtonDown="Pick2">
                    <Image x:Name="Img2" Stretch="UniformToFill" Height="320"/>
                </Border>
                <Button x:Name="BtnRetake2" Content="重拍(最多一次)" Height="60" FontSize="18"
                        Margin="8,0,8,0" Click="Retake2"/>
                <TextBlock x:Name="TxtFilter2" Foreground="#BBB" FontSize="16" Margin="8,8,8,0"/>
            </StackPanel>

            <StackPanel>
                <Border x:Name="PhotoBd3" Style="{StaticResource PhotoBorderStyle}"
                        MouseLeftButtonDown="Pick3">
                    <Image x:Name="Img3" Stretch="UniformToFill" Height="320"/>
                </Border>
                <Button x:Name="BtnRetake3" Content="重拍(最多一次)" Height="60" FontSize="18"
                        Margin="8,0,8,0" Click="Retake3"/>
                <TextBlock x:Name="TxtFilter3" Foreground="#BBB" FontSize="16" Margin="8,8,8,0"/>
            </StackPanel>

            <StackPanel>
                <Border x:Name="PhotoBd4" Style="{StaticResource PhotoBorderStyle}"
                        MouseLeftButtonDown="Pick4">
                    <Image x:Name="Img4" Stretch="UniformToFill" Height="320"/>
                </Border>
                <Button x:Name="BtnRetake4" Content="重拍(最多一次)" Height="60" FontSize="18"
                        Margin="8,0,8,0" Click="Retake4"/>
                <TextBlock x:Name="TxtFilter4" Foreground="#BBB" FontSize="16" Margin="8,8,8,0"/>
            </StackPanel>
        </UniformGrid>

        <!-- 右：濾鏡列表 -->
        <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,20,0,20">
            <TextBlock x:Name="ActiveHint" Foreground="White" FontSize="24" Margin="0,0,0,10"/>
            <WrapPanel>
                <ToggleButton x:Name="F_None" Style="{StaticResource FilterToggleStyle}" Content="原圖"
                              Tag="" Click="OnFilterClick"/>
                <ToggleButton x:Name="F_BW" Style="{StaticResource FilterToggleStyle}" Content="黑白"
                              Tag="bw" Click="OnFilterClick"/>
                <ToggleButton x:Name="F_Warm" Style="{StaticResource FilterToggleStyle}" Content="暖色"
                              Tag="warm" Click="OnFilterClick"/>
                <ToggleButton x:Name="F_Cool" Style="{StaticResource FilterToggleStyle}" Content="冷色"
                              Tag="cool" Click="OnFilterClick"/>
                <ToggleButton x:Name="F_Vivid" Style="{StaticResource FilterToggleStyle}" Content="鮮豔"
                              Tag="vivid" Click="OnFilterClick"/>
            </WrapPanel>

            <TextBlock Text="（現在先記錄濾鏡選擇，下一步合成時再真正套用）"
                       Foreground="#888" FontSize="14" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- 下方按鈕 -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="下一步：合成" Width="220" Height="80" FontSize="24" Margin="0,0,10,0"
                    Click="GoCompose"/>
            <Button Content="回到待機" Width="200" Height="80" FontSize="24" Click="BackToIdle"/>
        </StackPanel>
    </Grid>
</Page>
