<Page x:Class="PhotoBoothWin.Pages.TemplatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="選擇版型" Foreground="White" FontSize="42"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,30,0,30">
            <Button Content="版型 A" FontSize="28" Height="120" Click="OnTemplateA"/>
            <Button Content="版型 B" FontSize="28" Height="120" Click="OnTemplateB"/>
            <Button Content="版型 C" FontSize="28" Height="120" Click="OnTemplateC"/>
        </UniformGrid>

        <Button Grid.Row="2" Content="返回" Height="80" FontSize="24"
                HorizontalAlignment="Left" Width="200"
                Click="OnBack"/>
    </Grid>
</Page>

