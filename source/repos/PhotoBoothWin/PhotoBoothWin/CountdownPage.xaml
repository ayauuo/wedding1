<Page x:Class="PhotoBoothWin.Pages.CountdownPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="準備拍攝" Foreground="White" FontSize="40" HorizontalAlignment="Center"/>
            <TextBlock x:Name="CountdownText" Text="10" Foreground="White" FontSize="120"
                       HorizontalAlignment="Center" Margin="0,20,0,20"/>
            <TextBlock x:Name="TemplateText" Text="" Foreground="Gray" FontSize="24"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
